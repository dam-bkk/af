# Caddy interne du conteneur af-web — sert le dist statique précompressé.
# Le Caddy principal du VM (apps-caddy-1) fait le TLS et reverse_proxy vers ici.
:80 {
	root * /srv/af

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
		-Server
	}

	@immuable path /_astro/* /images/*
	header @immuable Cache-Control "public, max-age=31536000, immutable"

	encode zstd gzip
	try_files {path} {path}/index.html
	file_server {
		precompressed zstd gzip
	}

	handle_errors {
		rewrite * /404.html
		file_server
	}
}
